# ── LLM Provider ─────────────────────────────────────────────────────────────
# Groq gives us Llama 3.3 70B free tier — fast inference, good for evals
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Observability ─────────────────────────────────────────────────────────────
# LangSmith traces every LLM call — optional but recommended for debugging
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=verirag-prod

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (docker-compose): use the localhost URL below
# Production (Vercel + Supabase): get your URL from
#   Supabase Dashboard → Project → Settings → Database → URI (Transaction Pooler)
#   Format: postgresql+asyncpg://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
#
# IMPORTANT for Vercel: do NOT set CHROMA_PERSIST_DIR — the /tmp default is correct
DATABASE_URL=postgresql+asyncpg://verirag:verirag_secret@localhost:5432/verirag

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# LOCAL DEV ONLY — leave this commented for Vercel deployments.
# Vercel uses /tmp/chroma_data (ephemeral between cold starts — data is not persistent).
# CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=verirag_docs

# ── Embeddings ────────────────────────────────────────────────────────────────
# HuggingFace Inference API — no local model needed (avoids 500MB+ bundle on Vercel).
# Get a free token at https://huggingface.co/settings/tokens
# Without HF_TOKEN the API works anonymously with stricter rate limits.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── RAG Pipeline ─────────────────────────────────────────────────────────────
# MMR (max marginal relevance) balances relevance vs diversity in retrieval
RETRIEVAL_TOP_K=5
RETRIEVAL_LAMBDA=0.5           # MMR lambda: 0=max diversity, 1=max relevance

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
LOG_LEVEL=DEBUG
API_V1_PREFIX=/api/v1
