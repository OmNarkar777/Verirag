{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/main.py" },
    { "src": "/health", "dest": "backend/main.py" },
    { "src": "/diag(/.*)?", "dest": "backend/main.py" },
    { "src": "/docs", "dest": "backend/main.py" },
    { "src": "/redoc", "dest": "backend/main.py" },
    { "src": "/openapi.json", "dest": "backend/main.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
